# === Email Delivery ===
# Recipient email address for all digests
EMAIL_RECIPIENT=

# Sender email address (the "from" address)
EMAIL_SENDER=

# Email provider: "sendgrid" or "smtp"
EMAIL_PROVIDER=smtp

# === SendGrid (required if EMAIL_PROVIDER=sendgrid) ===
# Your SendGrid API key
SENDGRID_API_KEY=

# === SMTP (required if EMAIL_PROVIDER=smtp) ===
# SMTP server hostname
SMTP_HOST=
# SMTP server port (typically 587 for TLS)
SMTP_PORT=587
# SMTP authentication username
SMTP_USER=
# SMTP authentication password
SMTP_PASS=

# === ACRIS API ===
# NYC Open Data app token (optional, recommended for higher rate limits)
ACRIS_APP_TOKEN=

# === Logging ===
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
